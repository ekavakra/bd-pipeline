# ============================================
# BD Pipeline — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Application ---
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://bd_user:bd_password@localhost:5432/bd_pipeline?schema=public
DB_USER=bd_user
DB_PASSWORD=bd_password
DB_NAME=bd_pipeline

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT Auth ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud

# --- Transcription Sidecar (FastAPI) ---
TRANSCRIPTION_SERVICE_URL=http://localhost:5001

# --- AWS S3 / Cloudflare R2 ---
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=bd-pipeline-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=BD Pipeline

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# --- Google APIs ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# --- Lead Enrichment ---
CLEARBIT_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# --- Sentry ---
SENTRY_DSN=

# --- PostHog ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
