    "@sendgrid/mail": "^8.1.0",
    "@sentry/node": "^8.40.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.30.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
